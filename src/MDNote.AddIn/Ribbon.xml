<?xml version="1.0" encoding="utf-8" ?>
<customUI
  xmlns="http://schemas.microsoft.com/office/2009/07/customui"
  onLoad="RibbonLoaded">
  <ribbon>
    <tabs>
      <tab id="TabMDNote" label="MD Note" insertAfterMso="TabView">

        <group id="grpRender" label="Render">
          <button
            id="btnRenderPage"
            label="Render Page"
            imageMso="Refresh"
            size="large"
            onAction="OnRenderPage"
            keytip="R" />
          <button
            id="btnRenderSelection"
            label="Render Selection"
            imageMso="RefreshAll"
            size="large"
            onAction="OnRenderSelection"
            keytip="RS" />
          <toggleButton
            id="btnLiveMode"
            label="Live Mode"
            imageMso="PlayMacro"
            size="large"
            onAction="OnToggleLiveMode"
            getPressed="GetLiveModePressed"
            keytip="L" />
        </group>

        <group id="grpSource" label="Source">
          <button
            id="btnToggleSource"
            label="Toggle Source"
            imageMso="ViewCode"
            size="large"
            onAction="OnToggleSource"
            keytip="TS" />
          <button
            id="btnExportFile"
            label="Export File"
            imageMso="FileSaveAs"
            size="large"
            onAction="OnExportFile"
            keytip="EF" />
          <button
            id="btnExportClipboard"
            label="Export Clipboard"
            imageMso="Copy"
            size="large"
            onAction="OnExportClipboard"
            keytip="EC" />
          <button
            id="btnImportMd"
            label="Import MD"
            imageMso="FileOpen"
            size="large"
            onAction="OnImportMarkdown"
            keytip="IM" />
          <button
            id="btnPasteRender"
            label="Paste Render"
            imageMso="Paste"
            size="large"
            onAction="OnPasteRender"
            keytip="PR" />
        </group>

        <group id="grpTools" label="Tools">
          <button
            id="btnInsertToc"
            label="Insert TOC"
            imageMso="IndexInsert"
            size="large"
            onAction="OnInsertToc"
            keytip="T" />
          <button
            id="btnSettings"
            label="Settings"
            imageMso="ControlProperties"
            size="large"
            onAction="OnOpenSettings"
            keytip="S" />
          <button
            id="btnAbout"
            label="About"
            imageMso="Info"
            size="large"
            onAction="OnShowAbout"
            keytip="A" />
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>
